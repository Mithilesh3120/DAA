import java.util.*;

public class SelectionSort {
    public static void selectionSort(int[] arr) {
        int n = arr.length;

        for (int i = 0; i < n - 1; i++) {
            int min_idx = i;
            for (int j = i + 1; j < n; j++) {
                if (arr[j] < arr[min_idx]) {
                    min_idx = j;
                }
            }
            if (min_idx != i) {
                int temp = arr[min_idx];
                arr[min_idx] = arr[i];
                arr[i] = temp;
                System.out.println("After Pass " + (i + 1) + ": " + Arrays.toString(arr));
            } else {
                System.out.println("After Pass " + (i + 1) + ": " + Arrays.toString(arr) + " [Array is Sorted thus No swap needed...!!!]");
            }
        }
    }

    public static void main(String[] args) {
        try (Scanner sc = new Scanner(System.in)) {
            System.out.print("Enter number of elements: ");
            if (!sc.hasNextInt()) return;

            int size = sc.nextInt();
            int[] data = new int[size];

            System.out.println("Enter " + size + " integers:");
            for (int i = 0; i < size; i++) {
                data[i] = sc.nextInt();
            }

            System.out.println("\nInitial Array: " + Arrays.toString(data));
            System.out.println("----------------------------");

            selectionSort(data);

            System.out.println("----------------------------");
            System.out.println("Final Sorted Array: " + Arrays.toString(data));
        }
    }
}

