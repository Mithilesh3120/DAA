import java.util.Scanner;

class Point {
    int x, y;

    Point(int x, int y) {
        this.x = x;
        this.y = y;
    }
    public String toString() {
        return "(" + x + ", " + y + ")";
    }
}

public class Main {
    public static double calculateDistance(Point p1, Point p2) {
        return Math.sqrt(Math.pow(p1.x - p2.x, 2) + Math.pow(p1.y - p2.y, 2));
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter the number of points: ");
        int n = sc.nextInt();

        Point[] points = new Point[n];


        for (int i = 0; i < n; i++) {
            System.out.printf("Enter x and y for point %d: ", i + 1);
            int x = sc.nextInt();
            int y = sc.nextInt();
            points[i] = new Point(x, y);
        }

        double minDistance = Double.MAX_VALUE;
        Point pointA = null;
        Point pointB = null;

        System.out.println("\n--- Calculating Distances ---");

        for (int i = 0; i < n - 1; i++) {
            for (int j = i + 1; j < n; j++) {
                double d = calculateDistance(points[i], points[j]);


                System.out.printf("Comparing %s and %s | Distance: %.2f%n",
                                  points[i], points[j], d);

                if (d < minDistance) {
                    minDistance = d;
                    pointA = points[i];
                    pointB = points[j];
                }
            }
        }

        //System.out.println("\n==============================");
        System.out.println("RESULT: CLOSEST PAIR FOUND");
        //System.out.println("==============================");
        if (pointA != null && pointB != null) {
            System.out.printf("Points: %s and %s%n", pointA, pointB);
            System.out.printf("Minimum Distance: %.4f%n", minDistance);
        }

        sc.close();
    }
}

