import java.util.Scanner;

public class StringSearchAnalysis {

    public static int calculation(String str, String sub) {
        int n = str.length();
        int m = sub.length();
        int comp = 0;
        int ali = 0;
        System.out.println("\nGiven String:");
        for (int i = 0; i < n; i++) System.out.print(i % 10 + " ");
        System.out.println("(Index)");
        for (int i = 0; i < n; i++) System.out.print(str.charAt(i) + " ");
        System.out.println("(Text)");
        System.out.println("-".repeat(n * 2));
        for (int i = 0; i <= n - m; i++) {
            int j = 0;
            while (j < m && str.charAt(j + i) == sub.charAt(j)) {
                comp++;
                j++;
            }

            comp++;
            ali++;
            for (int k = 0; k < i; k++) System.out.print("  ");
            for (int l = 0; l < m; l++) System.out.print(sub.charAt(l) + " ");
            if (j == m) {
                System.out.println(" ---> MATCHED");
                comp--;
                printStats(ali, comp);
                return i;
            } else {
                System.out.println(" ----> NOT MATCHED");
            }
        }

        printStats(ali, comp);
        return -1;
    }

    private static void printStats(int ali, int comp) {
        System.out.println("-".repeat(20));
        System.out.println("Total Alignments:  " + ali);
        System.out.println("Total Comparisons: " + comp);
        System.out.println("-".repeat(20));
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("ENTER TEXT: ");
        String str = sc.nextLine();
        System.out.print("PATTERN TO BE SEARCHED IN THE STRING:   ");
        String sub = sc.nextLine();

        int result = calculation(str, sub);

        if (result == -1) {
            System.out.println("RES:PATTERN NOT FOUND");
        } else {
            System.out.println("RES:PATTERN FOUND " + result);
        }
        sc.close();
    }
}

