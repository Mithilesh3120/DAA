import java.util.*;

public class RankCountingSort {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter the number of elements: ");
        int n = sc.nextInt();

        int[] arr = new int[n];
        int[] ranks = new int[n];
        int[] output = new int[n];

        System.out.println("Enter " + n + " integers:");
        for (int i = 0; i < n; i++) arr[i] = sc.nextInt();

        System.out.println("\nOriginal Array: " + Arrays.toString(arr));
        System.out.println("\n--- Calculating Ranks ---");

        for (int i = 0; i < n - 1; i++) {
            for (int j = i + 1; j < n; j++) {
                if (arr[i] < arr[j]) {
                    ranks[j]++;
                } else {
                    ranks[i]++;
                }
            }
            System.out.println("Pass " + (i + 1) + ": " + Arrays.toString(ranks));
        }

        for (int i = 0; i < n; i++) {
            output[ranks[i]] = arr[i];
        }

        System.out.println("\nSorted Array: " + Arrays.toString(output));
        sc.close();
    }
}

